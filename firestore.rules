rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGroupMemberByData(groupData) {
      return isSignedIn() && request.auth.uid in groupData.members;
    }

    function isGroupAdminByData(groupData) {
      return isGroupMemberByData(groupData) &&
        (request.auth.uid == groupData.createdBy || request.auth.uid in groupData.admins);
    }

    function canUpdateGroupMessage(messageData) {
      return request.auth.uid == messageData.senderId ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy', 'reactions', 'deletedFor']);
    }

    function isSelfLeaveGroup() {
      return !(request.auth.uid in resource.data.admins) &&
        !(request.auth.uid in request.resource.data.members) &&
        resource.data.members.hasAll(request.resource.data.members) &&
        request.resource.data.members.size() == resource.data.members.size() - 1 &&
        request.resource.data.admins == resource.data.admins &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'lastTimestamp']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update, delete: if isSelf(userId);
    }

    match /chat_rooms/{roomId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn() &&
        request.resource.data.participants is list &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;

      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        function roomDoc() {
          return get(/databases/$(database)/documents/chat_rooms/$(roomId));
        }

        allow read: if isSignedIn() && request.auth.uid in roomDoc().data.participants;

        allow create: if isSignedIn() &&
          request.auth.uid == request.resource.data.senderId &&
          request.resource.data.senderId in roomDoc().data.participants &&
          request.resource.data.receiverId in roomDoc().data.participants;

        allow update: if isSignedIn() && request.auth.uid in roomDoc().data.participants;
        allow delete: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if isGroupMemberByData(resource.data);

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdBy &&
        request.auth.uid in request.resource.data.members &&
        request.auth.uid in request.resource.data.admins;

      allow update: if isGroupMemberByData(resource.data) && (
          isGroupAdminByData(resource.data) ||
          isSelfLeaveGroup() ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['typing', 'lastMessage', 'lastTimestamp'])
        );

      allow delete: if isGroupAdminByData(resource.data);

      match /messages/{messageId} {
        function groupDoc() {
          return get(/databases/$(database)/documents/groups/$(groupId));
        }

        allow read: if isSignedIn() && request.auth.uid in groupDoc().data.members;

        allow create: if isSignedIn() &&
          request.auth.uid in groupDoc().data.members &&
          request.auth.uid == request.resource.data.senderId;

        allow update: if isSignedIn() &&
          request.auth.uid in groupDoc().data.members &&
          canUpdateGroupMessage(resource.data);

        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
